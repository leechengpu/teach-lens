[
  {"segment_idx": 0, "start_sec": 0.0, "end_sec": 4.5, "text": "好同學們今天我們要來上自然課"},
  {"segment_idx": 1, "start_sec": 4.5, "end_sec": 9.2, "text": "我們今天的主題是水的三態變化"},
  {"segment_idx": 2, "start_sec": 9.2, "end_sec": 13.0, "text": "請大家把課本翻到第三十二頁"},
  {"segment_idx": 3, "start_sec": 13.0, "end_sec": 18.5, "text": "水的三態指的是固態液態跟氣態這三種狀態"},
  {"segment_idx": 4, "start_sec": 18.5, "end_sec": 22.0, "text": "那固態的水我們叫做什麼"},
  {"segment_idx": 5, "start_sec": 22.0, "end_sec": 22.6, "text": "冰"},
  {"segment_idx": 6, "start_sec": 22.6, "end_sec": 24.0, "text": "對就是冰"},
  {"segment_idx": 7, "start_sec": 24.0, "end_sec": 27.5, "text": "那液態的水大家都很熟悉就是我們平常喝的水"},
  {"segment_idx": 8, "start_sec": 27.5, "end_sec": 31.2, "text": "氣態的水叫做水蒸氣"},
  {"segment_idx": 9, "start_sec": 31.2, "end_sec": 35.0, "text": "水蒸氣我們看不到摸不到"},
  {"segment_idx": 10, "start_sec": 35.0, "end_sec": 38.8, "text": "那為什麼水會在這三種狀態之間變化呢"},
  {"segment_idx": 11, "start_sec": 38.8, "end_sec": 39.5, "text": "因為熱"},
  {"segment_idx": 12, "start_sec": 39.5, "end_sec": 42.5, "text": "對溫度改變就會讓水的狀態改變"},
  {"segment_idx": 13, "start_sec": 42.5, "end_sec": 47.2, "text": "當溫度降低到攝氏零度水會變成冰"},
  {"segment_idx": 14, "start_sec": 47.2, "end_sec": 51.5, "text": "當溫度上升到攝氏一百度水會變成水蒸氣"},
  {"segment_idx": 15, "start_sec": 51.5, "end_sec": 54.8, "text": "這個過程叫做物態變化"},
  {"segment_idx": 16, "start_sec": 54.8, "end_sec": 58.5, "text": "物態變化在我們生活中到處都看得到"},
  {"segment_idx": 17, "start_sec": 58.5, "end_sec": 62.0, "text": "誰可以舉一個生活中看到水的三態變化的例子"},
  {"segment_idx": 18, "start_sec": 62.0, "end_sec": 62.5, "text": "煮開水"},
  {"segment_idx": 19, "start_sec": 62.5, "end_sec": 65.0, "text": "對煮開水會冒出水蒸氣很好"},
  {"segment_idx": 20, "start_sec": 65.0, "end_sec": 67.0, "text": "還有別的例子嗎"},
  {"segment_idx": 21, "start_sec": 67.0, "end_sec": 67.5, "text": "下雪"},
  {"segment_idx": 22, "start_sec": 67.5, "end_sec": 70.0, "text": "下雪很好雪就是固態的水"},
  {"segment_idx": 23, "start_sec": 70.0, "end_sec": 73.5, "text": "好接下來我們來看課本上的圖"},
  {"segment_idx": 24, "start_sec": 73.5, "end_sec": 78.0, "text": "圖上面畫的是水分子在三種狀態下的排列方式"},
  {"segment_idx": 25, "start_sec": 78.0, "end_sec": 82.5, "text": "固態的時候水分子排得很整齊很緊密"},
  {"segment_idx": 26, "start_sec": 82.5, "end_sec": 86.5, "text": "液態的時候水分子可以自由移動但還是靠在一起"},
  {"segment_idx": 27, "start_sec": 86.5, "end_sec": 90.5, "text": "氣態的時候水分子分散得很開動得很快"},
  {"segment_idx": 28, "start_sec": 90.5, "end_sec": 94.0, "text": "那如果我把這杯水放在桌上會發生什麼事"},
  {"segment_idx": 29, "start_sec": 94.0, "end_sec": 94.7, "text": "蒸發"},
  {"segment_idx": 30, "start_sec": 94.7, "end_sec": 98.5, "text": "對水會慢慢蒸發變成水蒸氣"},
  {"segment_idx": 31, "start_sec": 98.5, "end_sec": 103.0, "text": "好今天的課就上到這裡有問題嗎"},
  {"segment_idx": 32, "start_sec": 103.0, "end_sec": 105.0, "text": "回家把第三十二頁的問題寫一寫"}
]
